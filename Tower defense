    if (e.button === 2) { isPanning = true; prevMouseX = e.clientX; prevMouseY = e.clientY; }
    if (e.button === 0 && e.shiftKey) { isOrbiting = true; prevMouseX = e.clientX; prevMouseY = e.clientY; }
});
