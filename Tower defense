<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Aether Grid - WebGL Tower Defense</title>
    <style>
        body { margin: 0; overflow: hidden; background-color: #0a0a11; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; user-select: none; }
        canvas { display: block; }
        
        #ui-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; color: white; padding: 20px; box-sizing: border-box; display: none; }
        
        #main-menu { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(10, 10, 17, 0.95); display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 2000; color: white; }
        #main-menu h1 { font-size: 48px; color: #00ffcc; text-shadow: 0 0 20px #00ffcc; margin-bottom: 40px; }
        .map-grid { display: flex; gap: 20px; }
        .map-card { background: #222; border: 2px solid #555; padding: 20px; border-radius: 12px; cursor: pointer; text-align: center; width: 160px; transition: 0.3s; }
        .map-card:hover { background: #333; border-color: #00ffcc; transform: translateY(-5px); }
