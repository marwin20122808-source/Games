function isPointOnPath(x, z) {
    const pt = new THREE.Vector2(x, z);
    for(let i=0; i<pathPoints.length-1; i++) {
        const p1 = new THREE.Vector2(pathPoints[i].x, pathPoints[i].z);
        const p2 = new THREE.Vector2(pathPoints[i+1].x, pathPoints[i+1].z);
        const l2 = p1.distanceToSquared(p2);
        if (l2 === 0) continue;
        let t = Math.max(0, Math.min(1, ((pt.x - p1.x) * (p2.x - p1.x) + (pt.y - p1.y) * (p2.y - p1.y)) / l2));
        const projection = new THREE.Vector2(p1.x + t * (p2.x - p1.x), p1.y + t * (p2.y - p1.y));
        if (pt.distanceToSquared(projection) <= 2.25) return true; 
    }
    return false;
}

// True Line of Sight Checker
const losRaycaster = new THREE.Raycaster();
function checkLineOfSight(startVec, endVec) {
    let dir = new THREE.Vector3().subVectors(endVec, startVec);
    let dist = dir.length(); dir.normalize();
    losRaycaster.set(startVec, dir);
    let hits = losRaycaster.intersectObjects(obstacleMeshes);
    for (let hit of hits) {
        if (hit.distance < 1.0) continue; // Ignore the roof we are sitting immediately on
        if (hit.distance < dist) return false;
    }
    return true;
}

