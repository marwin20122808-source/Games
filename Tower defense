<script>
/**
 * AAA TOWER DEFENSE - WebGL
 * ULTIMATE UPDATE: High Fidelity Procedural City, Advanced Raycasting, Full Architecture
 */

let gameStarted = false;
let obstacleMeshes = [];

// --- 0. CACHING & PROCEDURAL TEXTURES ---
function createBuildingMaterial(baseColor, windowLitColor, windowDarkColor) {
    let c = document.createElement('canvas'); c.width = 256; c.height = 256; 
    let ctx = c.getContext('2d');
    ctx.fillStyle = baseColor; ctx.fillRect(0, 0, 256, 256);
    
    let cols = 6; let rows = 8;
    let wWidth = 20; let wHeight = 24;
    let gapX = (256 - (cols * wWidth)) / (cols + 1);
    let gapY = (256 - (rows * wHeight)) / (rows + 1);
    
    for (let r = 0; r < rows; r++) {
        for (let cCol = 0; cCol < cols; cCol++) {
            let x = gapX + cCol * (wWidth + gapX);
            let y = gapY + r * (wHeight + gapY);
            
            ctx.fillStyle = (Math.random() < 0.3) ? windowLitColor : windowDarkColor;
            ctx.fillRect(x, y, wWidth, wHeight);
            
            ctx.strokeStyle = '#050505'; ctx.lineWidth = 2; ctx.strokeRect(x, y, wWidth, wHeight);
            ctx.beginPath(); ctx.moveTo(x + wWidth/2, y); ctx.lineTo(x + wWidth/2, y + wHeight);
            ctx.moveTo(x, y + wHeight/2); ctx.lineTo(x + wWidth, y + wHeight/2); ctx.stroke();
        }
    }
    
    let tex = new THREE.CanvasTexture(c);
    tex.wrapS = THREE.RepeatWrapping; tex.wrapT = THREE.RepeatWrapping; tex.anisotropy = 4;
    return new THREE.MeshStandardMaterial({ map: tex, roughness: 0.7, metalness: 0.3 });
}

const GeoCache = {
    dodecahedron: new THREE.DodecahedronGeometry(1),
    sphere: new THREE.SphereGeometry(1, 16, 16),
    box: new THREE.BoxGeometry(1, 1, 1),
    shield: new THREE.BoxGeometry(1.2, 1.2, 1.2),
    regrowAura: new THREE.TorusGeometry(1, 0.05, 8, 16),
    healthPlane: new THREE.PlaneGeometry(1.0, 0.15),
    coin: new THREE.CylinderGeometry(0.15, 0.15, 0.05, 8),
    cone: new THREE.ConeGeometry(0.5, 2, 8),
    cylinder: new THREE.CylinderGeometry(0.2, 0.2, 1, 8),
    rock: new THREE.DodecahedronGeometry(0.8)
};

const MatCache = {
    whiteFlash: new THREE.MeshStandardMaterial({ color: 0xffffff, emissive: 0x888888 }),
    shield: new THREE.MeshBasicMaterial({ color: 0xffffff, wireframe: true }),
    regrowAura: new THREE.MeshBasicMaterial({ color: 0xff0044 }),
    healthBg: new THREE.MeshBasicMaterial({ color: 0x000000, depthTest: false }),
    healthGreen: new THREE.MeshBasicMaterial({ color: 0x00ff00, depthTest: false }),
    healthYellow: new THREE.MeshBasicMaterial({ color: 0xffff00, depthTest: false }),
    healthRed: new THREE.MeshBasicMaterial({ color: 0xff0000, depthTest: false }),
    paragon: new THREE.MeshStandardMaterial({ color: 0xffffff, emissive: 0xffffff, emissiveIntensity: 0.8 }),
    coin: new THREE.MeshStandardMaterial({ color: 0xffd700, metalness: 0.8, roughness: 0.2 }),
    
    treeGreen: new THREE.MeshStandardMaterial({ color: 0x228822 }),
    treeTrunk: new THREE.MeshStandardMaterial({ color: 0x553311 }),
    cactus: new THREE.MeshStandardMaterial({ color: 0x44aa44 }),
    ice: new THREE.MeshStandardMaterial({ color: 0xaaddff, transparent: true, opacity: 0.8 }),
    rock: new THREE.MeshStandardMaterial({ color: 0x666666 }),
    lava: new THREE.MeshBasicMaterial({ color: 0xff3300 }),
    marble: new THREE.MeshStandardMaterial({ color: 0xeeeeee, roughness: 0.1 }),
    bankRoof: new THREE.MeshStandardMaterial({ color: 0x114488 }),
    wood: new THREE.MeshStandardMaterial({ color: 0x664422 }),
    leaf: new THREE.MeshStandardMaterial({ color: 0x339933 }),
    
    cityRoof: new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 1.0 }),
    acUnit: new THREE.MeshStandardMaterial({ color: 0x888888, metalness: 0.5, roughness: 0.5 }),
    b1: createBuildingMaterial('#2c2c35', '#ccffff', '#11111a'), // Modern Glass
    b2: createBuildingMaterial('#4a3b32', '#ffddaa', '#1a1510'), // Brown Brick
    b3: createBuildingMaterial('#404040', '#ffffff', '#111111'), // Dark Office
    b4: createBuildingMaterial('#666666', '#aaddff', '#222222')  // Concrete Tower
};

const EnemyMatCache = {}; const CamoMatCache = {};
const explosionPool = [];
function createExplosion(pos) {
    let exp = explosionPool.find(e => !e.active);
    if (!exp) {
        exp = { mesh: new THREE.Mesh(new THREE.SphereGeometry(2.5, 8, 8), new THREE.MeshBasicMaterial({ color: 0xff5500, transparent: true })), active: false, timer: 0 };
        scene.add(exp.mesh); explosionPool.push(exp);
    }
    exp.mesh.position.copy(pos); exp.mesh.scale.setScalar(1); exp.mesh.material.opacity = 0.8;
    exp.mesh.visible = true; exp.active = true; exp.timer = 0.3; 
}
function updateExplosions(dt) {
    for (let e of explosionPool) {
        if (e.active) { e.timer -= dt; e.mesh.scale.multiplyScalar(1 - (dt * 2.5)); e.mesh.material.opacity -= dt * 2.5; if (e.timer <= 0) { e.active = false; e.mesh.visible = false; } }
    }
}

const coinPool = [];
function spawnBankCoins(pos) {
    for(let i=0; i<8; i++) {
        let c = coinPool.find(x => !x.active);
        if (!c) {
            c = { mesh: new THREE.Mesh(GeoCache.coin, MatCache.coin), active: false, vel: new THREE.Vector3() };
            c.mesh.rotation.x = Math.PI/2; scene.add(c.mesh); coinPool.push(c);
        }
        c.mesh.position.copy(pos); c.mesh.position.y += 0.8;
        c.vel.set((Math.random()-0.5)*4, Math.random()*5 + 3, (Math.random()-0.5)*4);
        c.active = true; c.timer = 1.2; c.mesh.visible = true;
    }
}
function updateCoins(dt) {
    for (let c of coinPool) {
        if (c.active) {
            c.timer -= dt; c.vel.y -= 15 * dt; c.mesh.position.addScaledVector(c.vel, dt);
            c.mesh.rotation.y += dt * 10; c.mesh.rotation.x += dt * 5;
            if (c.timer <= 0 || c.mesh.position.y < 0) { c.active = false; c.mesh.visible = false; }
        }
    }
}

// --- 1. GAME SETTINGS & UI ---
let gameSpeed = 1.0;
function setSpeed(spd) {
    gameSpeed = spd;
    document.querySelectorAll('.spd-btn').forEach(b => b.classList.remove('active'));
    document.getElementById(`spd-${spd}`).classList.add('active');
}

function showFloatingText(text, position3D, color) {
    const vector = position3D.clone(); vector.y += 1.5; vector.project(camera);
    const x = (vector.x * 0.5 + 0.5) * window.innerWidth; const y = (vector.y * -0.5 + 0.5) * window.innerHeight;
    const el = document.createElement('div'); el.className = 'floating-text'; el.innerText = text;
    el.style.left = `${x}px`; el.style.top = `${y}px`; el.style.color = color;
    document.body.appendChild(el); setTimeout(() => el.remove(), 1200);
}

const GameState = {
    money: 1200, 
    lives: 40,
    wave: 1,
    maxWaves: 30,
    isGameOver: false,
    spend: function(amount) {
        if (this.money >= amount) { this.money -= amount; document.getElementById('money-display').innerText = Math.floor(this.money); return true; }
        return false;
    },
    addMoney: function(amount) { this.money += amount; document.getElementById('money-display').innerText = Math.floor(this.money); },
    takeDamage: function(amount) {
        if (this.isGameOver) return;
        this.lives -= amount; document.getElementById('lives-display').innerText = this.lives;
        if(this.lives <= 0) {
            this.isGameOver = true;
            const ann = document.getElementById('wave-announcer');
            ann.innerText = "GAME OVER"; ann.style.color = "#ff0000"; ann.style.opacity = 1;
        }
    },
    win: function() {
        this.isGameOver = true;
        const ann = document.getElementById('wave-announcer');
        ann.innerText = "VICTORY!"; ann.style.color = "#ffd700"; ann.style.opacity = 1;
    }
};

const ENEMY_TIERS = {
    1: { name: 'Red',    color: 0xff4444, hp: 1,  spd: 3.0, child: null, count: 0, reward: 2, size: 0.3 },
    2: { name: 'Blue',   color: 0x4444ff, hp: 1,  spd: 3.5, child: 1,    count: 1, reward: 2, size: 0.35 },
    3: { name: 'Green',  color: 0x44ff44, hp: 1,  spd: 4.0, child: 2,    count: 1, reward: 2, size: 0.4 },
    4: { name: 'Yellow', color: 0xffff44, hp: 1,  spd: 6.0, child: 3,    count: 1, reward: 3, size: 0.4 },
    5: { name: 'Pink',   color: 0xff44ff, hp: 1,  spd: 7.5, child: 4,    count: 1, reward: 4, size: 0.4 },
    6: { name: 'Black',  color: 0x222222, hp: 1,  spd: 3.5, child: 5,    count: 2, reward: 5, size: 0.45 },
    7: { name: 'Lead',   color: 0x888899, hp: 1,  spd: 2.5, child: 6,    count: 2, reward: 6, size: 0.45, isLead: true },
    8: { name: 'Zebra',  color: 0xffffff, hp: 1,  spd: 3.5, child: 6,    count: 2, reward: 5, size: 0.45 },
    9: { name: 'Rainbow',color: 0x00ffff, hp: 1,  spd: 5.0, child: 8,    count: 2, reward: 8, size: 0.5 },
    10:{ name: 'Ceramic',color: 0xb06030, hp: 10, spd: 4.5, child: 9,    count: 2, reward: 15,size: 0.55 },
    11:{ name: 'MOAB',   color: 0x00aaff, hp: 200,spd: 1.5, child: 10,   count: 4, reward: 100,size: 2.0, isBoss: true },
    12:{ name: 'BFB',    color: 0xff0000, hp: 700,spd: 1.0, child: 11,   count: 4, reward: 300,size: 3.0, isBoss: true },
    13:{ name: 'ZOMG',   color: 0x00ff00, hp: 4000,spd: 0.8,child: 12,   count: 4, reward: 1000,size: 4.0, isBoss: true },
    14:{ name: 'BAD',    color: 0x8800ff, hp: 20000,spd:0.7,child: 13,   count: 2, reward: 3000,size: 5.0, isBoss: true }
};

for(let tier in ENEMY_TIERS) {
    let def = ENEMY_TIERS[tier];
    if(def.isLead) {
        EnemyMatCache[tier] = new THREE.MeshStandardMaterial({ color: def.color, metalness: 0.8, roughness: 0.2 });
        CamoMatCache[tier] = new THREE.MeshStandardMaterial({ color: def.color, metalness: 0.8, roughness: 0.2, transparent: true, opacity: 0.4 });
    } else if (def.isCeramic) {
        EnemyMatCache[tier] = new THREE.MeshStandardMaterial({ color: def.color, roughness: 1.0 });
        CamoMatCache[tier] = new THREE.MeshStandardMaterial({ color: def.color, roughness: 1.0, transparent: true, opacity: 0.4 });
    } else {
        EnemyMatCache[tier] = new THREE.MeshStandardMaterial({ color: def.color });
        CamoMatCache[tier] = new THREE.MeshStandardMaterial({ color: def.color, transparent: true, opacity: 0.4 });
    }
}

const TOWER_TYPES = {
    'basic':  { name: 'Basic Tower',  cost: 300,  dmg: 2,  rng: 4.5, spd: 1.5, color: 0x888888, type: 'normal', popsLead: false, icon: '🚀' },
    'rapid':  { name: 'Rapid Tower',  cost: 400,  dmg: 1,  rng: 3.0, spd: 5.0, color: 0x2266cc, type: 'normal', popsLead: false, icon: '⚡' },
    'sniper': { name: 'Sniper Tower', cost: 600,  dmg: 15, rng: 15.0,spd: 0.3, color: 0x228822, type: 'normal', popsLead: false, icon: '🎯' },
