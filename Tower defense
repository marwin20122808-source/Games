const enemies = [];
class Enemy {
    constructor(tier, startProgress = 0, isRegrow = false, originalTier = null, isCamo = false) {
        this.active = true; this.tierId = tier; const def = ENEMY_TIERS[tier];
        this.isBoss = def.isBoss || false; this.isLead = def.isLead || false;
        this.isCeramic = tier === 10; this.isCamo = isCamo;
        this.maxHp = def.hp; this.hp = this.maxHp;
        this.speed = def.spd; this.reward = def.reward;
        this.childTier = def.child; this.childCount = def.count;
        this.isRegrow = isRegrow; this.maxTierId = originalTier || tier;
        this.timeSinceLastHit = 0; this.hitFlashTimer = 0; 

        this.progress = startProgress; this.totalPathLength = 0; this.segmentLengths = [];
        for(let i=0; i<pathPoints.length-1; i++) {
            let l = pathPoints[i].distanceTo(pathPoints[i+1]);
            this.segmentLengths.push(l); this.totalPathLength += l;
        }

        this.group = new THREE.Group(); this.updatePosition();
        this.speedMod = 1.0; this.slowTimer = 0; this.poisonTicks = 0; this.poisonTimer = 0;
        
        let geo = def.isBoss ? GeoCache.box : (def.isLead ? GeoCache.sphere : GeoCache.dodecahedron);
        this.mesh = new THREE.Mesh(geo, this.isCamo ? CamoMatCache[tier] : EnemyMatCache[tier]);
        this.mesh.scale.setScalar(def.size); this.group.add(this.mesh);

        if (this.isBoss) {
            this.shield = new THREE.Mesh(GeoCache.shield, MatCache.shield); this.shield.scale.setScalar(def.size);
            if(this.isCamo) { this.shield.material.transparent = true; this.shield.material.opacity = 0.4; }
            this.group.add(this.shield);
        }
        if (this.isRegrow) {
            this.regrowAura = new THREE.Mesh(GeoCache.regrowAura, MatCache.regrowAura);
            this.regrowAura.rotation.x = Math.PI/2; this.regrowAura.scale.setScalar(def.size * 1.5);
            this.group.add(this.regrowAura);
        }

        this.healthGroup = new THREE.Group();
        this.healthGroup.position.y = this.isBoss ? (def.size + 0.5) : 0.8;
        const bgBar = new THREE.Mesh(GeoCache.healthPlane, MatCache.healthBg); bgBar.position.z = -0.01;
        this.healthBar = new THREE.Mesh(GeoCache.healthPlane, MatCache.healthGreen);
        this.healthGroup.add(bgBar); this.healthGroup.add(this.healthBar);
        this.group.add(this.healthGroup); scene.add(this.group);
    }

    updatePosition() {
        let remaining = this.progress;
        for(let i=0; i<this.segmentLengths.length; i++) {
            if (remaining <= this.segmentLengths[i]) {
                const alpha = remaining / this.segmentLengths[i];
                this.group.position.lerpVectors(pathPoints[i], pathPoints[i+1], alpha);
                return;
            }
            remaining -= this.segmentLengths[i];
        }
        this.destroy(); GameState.takeDamage(this.isBoss ? 20 : (this.isCeramic ? 10 : 1));
    }

    update(dt) {
        if (!this.active) return;
        if (this.hitFlashTimer > 0) {
            this.hitFlashTimer -= dt;
            if (this.hitFlashTimer <= 0) this.mesh.material = this.isCamo ? CamoMatCache[this.tierId] : EnemyMatCache[this.tierId];
        }

        this.timeSinceLastHit += dt;
        if (this.isRegrow && this.timeSinceLastHit > 3.0 && this.tierId < this.maxTierId) {
            enemies.push(new Enemy(this.tierId + 1, this.progress, true, this.maxTierId, this.isCamo));
            this.destroy(); return;
        }
        
        if (this.slowTimer > 0) { this.slowTimer -= dt; if (this.slowTimer <= 0) this.speedMod = 1.0; }
        if (this.poisonTicks > 0) {
            this.poisonTimer -= dt;
            if (this.poisonTimer <= 0) { this.takeDamage(1, true, true); this.poisonTicks--; this.poisonTimer = 0.5; }
        }

        if (this.isBoss) { this.shield.rotation.x += dt; this.shield.rotation.y += dt; }
        if (this.isRegrow && this.regrowAura) this.regrowAura.rotation.z += dt * 3; 
        this.healthGroup.lookAt(camera.position);

        this.progress += (this.speed * this.speedMod) * dt; this.updatePosition();
    }

    takeDamage(amt, silent = false, bypassLead = false) {
        if (!this.active) return;
        this.timeSinceLastHit = 0; 
        if (this.isLead && !bypassLead) return; 

        this.hp -= amt;
        const pct = Math.max(0, this.hp / this.maxHp);
        this.healthBar.scale.x = Math.max(0.01, pct); this.healthBar.position.x = (pct - 1) * 0.5;
        if (pct < 0.25) this.healthBar.material = MatCache.healthRed;
        else if (pct < 0.5) this.healthBar.material = MatCache.healthYellow;
        else this.healthBar.material = MatCache.healthGreen;

        if (!silent) { this.mesh.material = MatCache.whiteFlash; this.hitFlashTimer = 0.05; }

        if (this.hp <= 0) {
            GameState.addMoney(this.reward); 
            if (this.childTier) {
                for(let i=0; i<this.childCount; i++) {
                    enemies.push(new Enemy(this.childTier, Math.max(0, this.progress - (i * 0.4)), this.isRegrow, this.maxTierId, this.isCamo));
                }
            }
            if (this.isBoss) showFloatingText(`BOSS DOWN`, this.group.position, '#00ffcc');
            this.destroy();
        }
    }

    destroy() { this.active = false; scene.remove(this.group); }
}

// --- WAVE MANAGER ---
const WaveManager = {
    waveQueue: [], spawnTimer: 0, state: 'waiting', 
    startWave: function() {
        if(GameState.wave > GameState.maxWaves) { GameState.win(); return; }
        document.getElementById('wave-display').innerText = GameState.wave;
        const ann = document.getElementById('wave-announcer');
        ann.innerText = `WAVE ${GameState.wave}`; ann.style.opacity = 1; setTimeout(() => ann.style.opacity = 0, 2000);
        
        this.waveQueue = []; let w = GameState.wave;
        let hasCamo = w >= 12; let isCamoWave = w === 15 || w === 22; 

        if (w === 10) { this.waveQueue.push({ tier: 11, delay: 3.0, regrow: false, camo: false }); } 
        else if (w === 20) { this.waveQueue.push({ tier: 12, delay: 3.0, regrow: false, camo: true }); } 
        else if (w === 25) { this.waveQueue.push({ tier: 13, delay: 3.0, regrow: false, camo: false }); } 
        else if (w === 30) { this.waveQueue.push({ tier: 14, delay: 3.0, regrow: false, camo: true }); } 
        else {
            let maxTier = Math.min(10, Math.floor(w / 2) + 1);
            let count = 10 + (w * 5); let hasRegrow = w > 5; let hasLeads = w > 7;
            for(let i=0; i<count; i++) {
                let t = Math.max(1, Math.ceil(Math.random() * maxTier));
                if (t === 7 && !hasLeads) t = 6; if (t > 10) t = 10; 
                let isR = hasRegrow ? (Math.random() < 0.25) : false; 
                let isC = isCamoWave ? true : (hasCamo && Math.random() < 0.2);
                this.waveQueue.push({ tier: t, delay: Math.max(0.15, 0.8 - (w*0.02)), regrow: isR, camo: isC });
            }
            this.waveQueue.sort((a,b) => a.tier - b.tier); 
        }
        this.state = 'spawning';
    },
    update: function(dt) {
        if (GameState.isGameOver) return;
        if (this.state === 'spawning') {
            this.spawnTimer -= dt;
            if (this.spawnTimer <= 0 && this.waveQueue.length > 0) {
                let next = this.waveQueue.shift();
                enemies.push(new Enemy(next.tier, 0, next.regrow, null, next.camo));
                this.spawnTimer = next.delay;
            }
            if (this.waveQueue.length === 0) this.state = 'active'; 
        } 
        else if (this.state === 'active') {
            if (enemies.length === 0) {
                this.state = 'waiting'; GameState.addMoney(300 + (GameState.wave * 50)); GameState.wave++;
                if (GameState.wave <= GameState.maxWaves) setTimeout(() => { this.startWave(); }, 4000);
                else GameState.win();
            }
        }
    }
};

