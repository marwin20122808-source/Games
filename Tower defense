            let hut2 = new THREE.Mesh(new THREE.CylinderGeometry(0.2, 0.2, 0.3, 8), MatCache.wood); hut2.position.set(0.3, 0.15, 0.3);
            let roof2 = new THREE.Mesh(new THREE.ConeGeometry(0.3, 0.3, 8), MatCache.leaf); roof2.position.set(0.3, 0.45, 0.3);
            this.group.add(this.baseMesh, roof, hut2, roof2);
            
            this.aura = new THREE.Mesh(GeoCache.regrowAura, new THREE.MeshBasicMaterial({color:0x00ffcc, transparent:true, opacity:0.3}));
            this.aura.rotation.x = Math.PI/2; this.aura.scale.setScalar(this.range); this.group.add(this.aura);
        }
        else {
            this.baseMesh = new THREE.Mesh(new THREE.BoxGeometry(1.2, 0.4, 1.2), this.baseMat);
            this.baseMesh.position.y = 0.2; this.group.add(this.baseMesh);
            this.turretGroup.position.y = 0.6;
            
            if (typeId === 'sniper') {
                this.turretCore = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.4, 0.5), this.turretMat);
                let barrel = new THREE.Mesh(new THREE.CylinderGeometry(0.05, 0.05, 1.5, 8), new THREE.MeshStandardMaterial({color:0x111111}));
                barrel.rotation.x = Math.PI/2; barrel.position.z = 0.75;
                let scope = new THREE.Mesh(new THREE.BoxGeometry(0.1, 0.1, 0.4), new THREE.MeshStandardMaterial({color:0x000000}));
                scope.position.set(0, 0.25, 0.2);
                this.barrelGroup.add(barrel, scope);
                this.muzzle.position.set(0, 0, 1.5); this.barrelGroup.add(this.muzzle);
            }
            else if (typeId === 'rapid') {
                this.turretCore = new THREE.Mesh(new THREE.CylinderGeometry(0.4, 0.4, 0.5, 8), this.turretMat); this.turretCore.rotation.x = Math.PI/2;
                for(let i=0; i<4; i++) {
                    let b = new THREE.Mesh(new THREE.CylinderGeometry(0.05, 0.05, 0.8, 8), new THREE.MeshStandardMaterial({color:0x111111}));
                    b.rotation.x = Math.PI/2; b.position.set(Math.cos(i*Math.PI/2)*0.15, Math.sin(i*Math.PI/2)*0.15, 0.4);
                    this.barrelGroup.add(b);
                }
                this.muzzle.position.set(0, 0, 0.8); this.barrelGroup.add(this.muzzle);
            }
            else if (typeId === 'cannon') {
                this.turretCore = new THREE.Mesh(GeoCache.sphere, this.turretMat); this.turretCore.scale.setScalar(0.5);
                let barrel = new THREE.Mesh(new THREE.CylinderGeometry(0.2, 0.2, 1.0, 8), new THREE.MeshStandardMaterial({color:0x111111}));
                barrel.rotation.x = Math.PI/2; barrel.position.z = 0.5;
                this.barrelGroup.add(barrel);
                this.muzzle.position.set(0, 0, 1.0); this.barrelGroup.add(this.muzzle);
            }
            else if (typeId === 'laser') {
                this.turretCore = new THREE.Mesh(GeoCache.sphere, this.turretMat); this.turretCore.scale.setScalar(0.4);
                let ring = new THREE.Mesh(new THREE.TorusGeometry(0.3, 0.05, 8, 16), new THREE.MeshStandardMaterial({color:0x00ffff}));
                ring.position.z = 0.5; this.barrelGroup.add(ring);
                this.muzzle.position.set(0, 0, 0.5); this.barrelGroup.add(this.muzzle);
            }
            else {
                this.turretCore = new THREE.Mesh(new THREE.CylinderGeometry(0.4, 0.4, 0.5, 8), this.turretMat); this.turretCore.rotation.x = Math.PI/2;
                let mainBarrel = new THREE.Mesh(new THREE.CylinderGeometry(0.1, 0.1, 0.8, 8), new THREE.MeshStandardMaterial({color:0x111111}));
                mainBarrel.rotation.x = Math.PI/2; mainBarrel.position.z = 0.4; this.barrelGroup.add(mainBarrel);
                this.muzzle.position.set(0, 0, 0.8); this.barrelGroup.add(this.muzzle);
            }
            this.turretGroup.add(this.turretCore); this.group.add(this.turretGroup);
        }

        this.hitbox = new THREE.Mesh(new THREE.BoxGeometry(1.5, 2.0, 1.5), new THREE.MeshBasicMaterial({visible: false}));
        this.hitbox.position.y = 1.0; this.hitbox.userData = { tower: this }; this.group.add(this.hitbox);

        const ringGeo = new THREE.RingGeometry(this.range - 0.1, this.range, 32);
        this.rangeRing = new THREE.Mesh(ringGeo, new THREE.MeshBasicMaterial({ color: 0xffffff, side: THREE.DoubleSide, transparent: true, opacity: 0.3 }));
        this.rangeRing.rotation.x = Math.PI / 2; this.rangeRing.position.y = 0.05; this.rangeRing.visible = false;
        this.group.add(this.rangeRing);

        this.beamMat = new THREE.LineBasicMaterial({ color: this.beamColor, linewidth: 3 });
        this.beamGeo = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(), new THREE.Vector3()]);
        this.beamLine = new THREE.Line(this.beamGeo, this.beamMat);
        this.beamLine.visible = false; this.beamTimer = 0; scene.add(this.beamLine);
        scene.add(this.group);
    }

    getSellValue() { return Math.floor(this.totalSpent * 0.75); }
    destroy() { scene.remove(this.group); scene.remove(this.beamLine); if(this.hasAbility) syncGlobalAbilities(); }

    useAbility() {
        if (!this.hasAbility || this.abilityCooldown > 0) return;
        this.abilityCooldown = this.isParagon ? this.abilityMaxCooldown/2 : this.abilityMaxCooldown; 

        if (this.typeId === 'basic') {
            let target = enemies.filter(e => e.active).sort((a,b) => b.hp - a.hp)[0];
            if(target) {
                createExplosion(target.group.position);
                let dmg = this.isParagon ? 1000 : 100;
                enemies.forEach(e => { if(e.active && e.group.position.distanceToSquared(target.group.position) < 16.0) e.takeDamage(dmg, false, true); });
                showFloatingText("ORBITAL STRIKE!", target.group.position, '#ff0000');
            }
        }
        else if (this.typeId === 'rapid') { this.abilityActiveTimer = 5.0; this.turretCore.material.emissive.setHex(0xffaa00); }
        else if (this.typeId === 'sniper') {
            let target = enemies.filter(e => e.active && (!e.isBoss || this.isParagon)).sort((a,b) => b.hp - a.hp)[0];
            if(target) { target.takeDamage(this.isParagon ? 15000 : 9999, false, true); showFloatingText("ASSASSINATED!", target.group.position, '#ff0000'); }
        }
        else if (this.typeId === 'bank') {
            let cash = this.isParagon ? 5000 : 1000; GameState.addMoney(cash); 
            showFloatingText(`STIMULUS +$${cash}`, this.group.position, '#ffd700'); spawnBankCoins(this.group.position);
        }
        else if (this.typeId === 'cannon') {
            let dmg = this.isParagon ? 500 : 20; enemies.forEach(e => { if(e.active) e.takeDamage(dmg, false, true); });
            showFloatingText("NUKE!", new THREE.Vector3(0,5,0), '#ffaa00');
        }
    }

    ascend() {
        if (GameState.spend(15000)) {
            this.isParagon = true; this.totalSpent += 15000; this.name = "PARAGON " + this.name;
            this.damage *= 10; this.baseFireRate *= 3; this.range += 5.0; this.canPopLead = true; this.canDetectCamo = true;

            if(this.typeId === 'bank' || this.typeId === 'village') {} 
            else { this.baseMesh.material = MatCache.paragon; this.turretCore.material = MatCache.paragon; }
            
            this.rangeRing.geometry.dispose(); this.rangeRing.geometry = new THREE.RingGeometry(this.range - 0.1, this.range, 32);
            showFloatingText("ASCENDED", this.group.position, '#ffffff'); updateUI();
        }
    }

    update(dt) {
        if (this.abilityCooldown > 0) this.abilityCooldown -= dt;
        if (this.beamTimer > 0) { this.beamTimer -= dt; if (this.beamTimer <= 0) this.beamLine.visible = false; }
        
        let currentFireRate = this.baseFireRate * this.buffedSpeed;
        if (this.abilityActiveTimer > 0) {
            this.abilityActiveTimer -= dt; currentFireRate *= 5; 
            if (this.abilityActiveTimer <= 0 && !this.isParagon && this.turretCore) this.turretCore.material.emissive.setHex(0x000000);
        }

        if (this.attackType === 'income') {
            this.fireCooldown -= dt;
            if (this.fireCooldown <= 0) {
                const amt = (20 + (this.tiers[0] * 10)) * (this.isParagon ? 5 : 1); 
                GameState.addMoney(amt); this.fireCooldown = 1.0 / currentFireRate;
                spawnBankCoins(this.group.position);
            }
            return;
        }
        
        if (this.typeId === 'village') {
            if(this.aura) this.aura.scale.setScalar(this.range + Math.sin(Date.now() * 0.005) * 0.2); 
            return; 
        }

        if (this.typeId === 'laser') this.barrelGroup.rotation.z += dt * 10;
        if (this.typeId === 'rapid') this.barrelGroup.rotation.z += dt * 5;

        const target = this.findTarget();
        if (target) {
            let lookPos = target.group.position.clone(); lookPos.y = this.turretGroup.position.y;
            const targetQuat = new THREE.Quaternion().setFromRotationMatrix(new THREE.Matrix4().lookAt(this.turretGroup.position, lookPos, new THREE.Vector3(0,1,0)));
            this.turretGroup.quaternion.slerp(targetQuat, 10 * dt);

            this.fireCooldown -= dt;
            if (this.fireCooldown <= 0) { this.shoot(target); this.fireCooldown = 1.0 / currentFireRate; }
        }
    }

    findTarget() {
        let bestTarget = null; let maxProgress = -1; const rangeSq = this.range * this.range; 
        
        let fireOrigin = new THREE.Vector3();
        if(this.muzzle) this.muzzle.getWorldPosition(fireOrigin);
        else fireOrigin.copy(this.group.position).add(new THREE.Vector3(0, 1, 0));

        for (let e of enemies) {
            if (e.active) {
                if (e.isCamo && !this.canDetectCamo && !this.buffedCamo) continue;
                if (this.group.position.distanceToSquared(e.group.position) <= rangeSq) {
                    if (obstacleMeshes.length > 0 && !checkLineOfSight(fireOrigin, e.group.position)) continue;
                    if (e.progress > maxProgress) { maxProgress = e.progress; bestTarget = e; }
                }
            }
        }
        return bestTarget;
    }

    shoot(target) {
        if (target.isLead && !this.canPopLead) return; 

        let startPoint = new THREE.Vector3(); this.muzzle.getWorldPosition(startPoint);
        const endPoint = target.group.position.clone();
        
        const positions = this.beamGeo.attributes.position.array;
        positions[0] = startPoint.x; positions[1] = startPoint.y; positions[2] = startPoint.z;
        positions[3] = endPoint.x;   positions[4] = endPoint.y;   positions[5] = endPoint.z;
        this.beamGeo.attributes.position.needsUpdate = true;
        this.beamLine.visible = true; this.beamTimer = 0.05; 
        
        if (this.attackType === 'splash') {
            createExplosion(target.group.position);
            enemies.forEach(e => { if (e.active && e.group.position.distanceToSquared(target.group.position) < 6.25) e.takeDamage(this.damage, false, this.canPopLead); });
        } else if (this.attackType === 'slow') {
            target.takeDamage(this.damage, false, this.canPopLead); target.applySlow(this.isParagon ? 0.1 : 0.4, 2.0); 
        } else if (this.attackType === 'dot') {
            target.takeDamage(this.damage, false, this.canPopLead); target.applyPoison(5 + this.tiers[0]*2); 
        } else {
            target.takeDamage(this.damage, false, this.canPopLead);
        }
    }

    updateVisuals() {
        if(this.typeId === 'village' || this.typeId === 'bank') return;
        if (this.tiers[0] >= 3 && this.typeId === 'basic' && this.barrelGroup.children.length === 1) {
            const b2 = new THREE.Mesh(new THREE.CylinderGeometry(0.1, 0.1, 0.8, 8), new THREE.MeshStandardMaterial({color:0x111111}));
            b2.rotation.x = Math.PI/2; b2.position.set(-0.2, 0, 0.4);
            const b3 = b2.clone(); b3.position.set(0.2, 0, 0.4);
            this.barrelGroup.add(b2, b3);
        }
        if (this.tiers[2] >= 3 && !this.radar) {
            this.radar = new THREE.Mesh(new THREE.ConeGeometry(0.3, 0.2, 8), new THREE.MeshStandardMaterial({color:0x00aaff}));
            this.radar.position.set(0, 0.5, -0.2); this.radar.rotation.x = -Math.PI/4;
            this.turretGroup.add(this.radar);
        }
        if (this.tiers[0] >= 5 && !this.hasAbility) {
            this.hasAbility = true;
            if(!this.isParagon) this.turretCore.material.color.setHex(0xaa00ff); 
            syncGlobalAbilities();
        }
    }

    select(isSelected) {
        this.rangeRing.visible = isSelected;
        if(!this.isParagon && this.baseMat && this.typeId !== 'bank' && this.typeId !== 'village') this.baseMat.emissive.setHex(isSelected ? 0x444444 : 0x000000);
    }
}

// --- 6. PLACEMENT, GHOST PREVIEW, ROOFS & SCENERY REMOVAL ---
const raycaster = new THREE.Raycaster(); const mouse = new THREE.Vector2();
let placingMode = false; let removeMode = false; let selectedTowerToBuild = null;

const ghostGeo = new THREE.BoxGeometry(1.2, 1.2, 1.2);
const ghostMat = new THREE.MeshBasicMaterial({ color: 0x00ff00, transparent: true, opacity: 0.6 });
const ghostCursor = new THREE.Mesh(ghostGeo, ghostMat); ghostCursor.visible = false; scene.add(ghostCursor);

function toggleBuildMode(typeId) {
    removeMode = false; document.getElementById('btn-remove-scenery').classList.remove('remove-mode');
    document.querySelectorAll('.build-btn').forEach(b => b.classList.remove('active'));
    if (placingMode && selectedTowerToBuild === typeId) { 
        placingMode = false; selectedTowerToBuild = null; ghostCursor.visible = false;
    } else { 
        placingMode = true; selectedTowerToBuild = typeId; 
        document.getElementById('btn-build-' + typeId).classList.add('active'); 
        selectTower(null); ghostCursor.visible = true;
    }
}

function toggleRemoveMode() {
    placingMode = false; selectedTowerToBuild = null; ghostCursor.visible = false;
    document.querySelectorAll('.build-btn').forEach(b => b.classList.remove('active'));
    removeMode = !removeMode;
    const btn = document.getElementById('btn-remove-scenery');
    if (removeMode) btn.classList.add('remove-mode'); else btn.classList.remove('remove-mode');
}

function sellTower() {
    if (!selectedTower) return;
    GameState.addMoney(selectedTower.getSellValue()); towers.splice(towers.indexOf(selectedTower), 1);
    selectedTower.destroy(); selectTower(null);
}

window.addEventListener('pointermove', (event) => {
    if (!placingMode || !gameStarted) return;
    mouse.x = (event.clientX / window.innerWidth) * 2 - 1; mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;
    raycaster.setFromCamera(mouse, camera);

    const intersects = raycaster.intersectObjects([groundPlane, ...obstacleMeshes]);
    if (intersects.length > 0) {
        let hit = intersects[0]; let pos = hit.point; let snapX = Math.round(pos.x); let snapZ = Math.round(pos.z);
        let placeY = 0.5;

        if (hit.object.userData && hit.object.userData.isBuilding) {
            if (hit.face.normal.y > 0.9) placeY = hit.object.userData.roofHeight; else return; 
        }

        ghostCursor.position.set(snapX, placeY + 0.1, snapZ);
        let occupied = towers.some(t => Math.abs(t.group.position.x - snapX) < 0.1 && Math.abs(t.group.position.z - snapZ) < 0.1 && Math.abs(t.group.position.y - placeY) < 0.1);
        let onPath = placeY <= 0.5 && isPointOnPath(snapX, snapZ); 
        
        if (occupied || onPath) ghostCursor.material.color.setHex(0xff0000);
        else ghostCursor.material.color.setHex(0x00ff00);
    }
});

window.addEventListener('pointerdown', (event) => {
    if (!gameStarted || event.target.tagName === 'BUTTON' || event.target.closest('.panel') || event.target.closest('.speed-controls') || event.target.closest('#ability-bar')) return;
    mouse.x = (event.clientX / window.innerWidth) * 2 - 1; mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;
    raycaster.setFromCamera(mouse, camera);

    if (removeMode) {
        const intersects = raycaster.intersectObjects(obstacleMeshes);
        if (intersects.length > 0) {
            let obj = intersects[0].object;
            if (GameState.spend(100)) {
                if (obj.userData.parentGroup) sceneryGroup.remove(obj.userData.parentGroup);
                else sceneryGroup.remove(obj);
                obstacleMeshes = obstacleMeshes.filter(m => m !== obj);
                showFloatingText("BULLDOZED", obj.position, '#ff4444');
            }
        }
        return;
    }

    if (placingMode && selectedTowerToBuild) {
        const intersects = raycaster.intersectObjects([groundPlane, ...obstacleMeshes]);
        if (intersects.length > 0) {
            let hit = intersects[0]; let pos = hit.point; let snapX = Math.round(pos.x); let snapZ = Math.round(pos.z);
            let placeY = 0.5;

            if (hit.object.userData && hit.object.userData.isBuilding) {
                if (hit.face.normal.y > 0.9) placeY = hit.object.userData.roofHeight; else return; 
            }

            let occupied = towers.some(t => Math.abs(t.group.position.x - snapX) < 0.1 && Math.abs(t.group.position.z - snapZ) < 0.1 && Math.abs(t.group.position.y - placeY) < 0.1);
            let onPath = placeY <= 0.5 && isPointOnPath(snapX, snapZ); 
            
            if (!occupied && !onPath) {
                const def = TOWER_TYPES[selectedTowerToBuild];
                if (GameState.spend(def.cost)) {
                    const newTower = new Tower(snapX, placeY, snapZ, selectedTowerToBuild);
                    towers.push(newTower); toggleBuildMode(selectedTowerToBuild); selectTower(newTower);
                }
            }
        }
    } else {
        const towerHitboxes = towers.map(t => t.hitbox);
        const intersects = raycaster.intersectObjects(towerHitboxes);
        if (intersects.length > 0) selectTower(intersects[0].object.userData.tower);
        else selectTower(null);
    }
});

// --- 7. UPGRADE SYSTEM ---
const UpgradeCosts = [ [200,400,800,1500,4000], [150,300,700,1200,3000], [100,200,400,800,2000] ];

function selectTower(tower) {
    if (selectedTower) selectedTower.select(false);
    selectedTower = tower;
    const panel = document.getElementById('upgrade-panel');
    if (tower) { tower.select(true); panel.style.display = 'block'; updateUI(); } 
    else panel.style.display = 'none';
}

function upgradeSelectedTower(pathIndex) {
    if (!selectedTower || selectedTower.isParagon) return;
    const tier = selectedTower.tiers[pathIndex];
    if (tier >= 5) return;
    
    let maxTier = 0; for (let i = 0; i < 3; i++) if (selectedTower.tiers[i] > maxTier) maxTier = selectedTower.tiers[i];
    if (maxTier >= 3 && tier === 2 && pathIndex !== selectedTower.tiers.indexOf(maxTier)) return;

    const cost = UpgradeCosts[pathIndex][tier];
    if (GameState.spend(cost)) {
        selectedTower.totalSpent += cost; selectedTower.tiers[pathIndex]++;
        if (pathIndex === 0) selectedTower.damage *= 1.5; 
        if (pathIndex === 1) selectedTower.baseFireRate *= 1.3; selectedTower.fireRate = selectedTower.baseFireRate;
        if (pathIndex === 2) {
            selectedTower.range *= 1.25;
            selectedTower.rangeRing.geometry.dispose();
            selectedTower.rangeRing.geometry = new THREE.RingGeometry(selectedTower.range - 0.1, selectedTower.range, 32);
            if(selectedTower.typeId === 'village') selectedTower.aura.scale.setScalar(selectedTower.range);
        }
        selectedTower.updateVisuals(); updateUI();
    }
}

function ascendToParagon() { if(selectedTower) selectedTower.ascend(); }

function updateUI() {
    if (!selectedTower) return;
    document.getElementById('tower-name').innerText = selectedTower.name;
    document.getElementById('tower-stats').innerText = `DMG: ${Math.round(selectedTower.damage)} | SPD: ${selectedTower.fireRate.toFixed(1)}/s | RNG: ${selectedTower.range.toFixed(1)}`;
    document.getElementById('btn-sell').innerText = `Sell for $${selectedTower.getSellValue()}`;

    let hasTier5 = false;
    for(let i=0; i<3; i++) {
        const tier = selectedTower.tiers[i];
        if (tier >= 5) hasTier5 = true;
        document.getElementById(`tier${i+1}-display`).innerText = `${tier}/5`;
        let locked = tier === 5 || selectedTower.isParagon; 
        let maxTier = 0; let maxIndex = -1;
        for (let j=0; j<3; j++) if (selectedTower.tiers[j] > maxTier) { maxTier = selectedTower.tiers[j]; maxIndex = j; }
        if (maxTier >= 3 && tier === 2 && i !== maxIndex) locked = true;
        
        const btn = document.getElementById(`btn-path${i+1}`);
        if (!locked) { document.getElementById(`cost${i+1}-display`).innerText = UpgradeCosts[i][tier]; btn.disabled = false; btn.style.opacity = 1.0; } 
        else { document.getElementById(`cost${i+1}-display`).innerText = "MAX/LOCKED"; btn.disabled = true; btn.style.opacity = 0.4; }
    }
    
    const btnParagon = document.getElementById('btn-paragon');
    if (hasTier5 && !selectedTower.isParagon) { btnParagon.style.display = 'block'; btnParagon.disabled = GameState.money < 15000; } 
    else btnParagon.style.display = 'none';
}

function applyVillageBuffs() {
    towers.forEach(t => { t.buffedSpeed = 1.0; t.buffedCamo = false; });
    let villages = towers.filter(t => t.typeId === 'village');
    villages.forEach(v => {
        const rangeSq = v.range * v.range;
        towers.forEach(t => { if (t !== v && v.group.position.distanceToSquared(t.group.position) <= rangeSq) { t.buffedSpeed = 1.25; t.buffedCamo = true; } });
    });
}

// --- 8. GAME LOOP ---
const clock = new THREE.Clock();
function animate() {
    requestAnimationFrame(animate); 
    if (!gameStarted) { renderer.render(scene, camera); return; }

    const dt = clock.getDelta() * gameSpeed;
    
    startPortal.rotation.y += dt * 1.5; endCore.rotation.x += dt * 0.5; endCore.rotation.y += dt * 0.5;

    applyVillageBuffs();
    WaveManager.update(dt);
    towers.forEach(t => t.update(dt));
    updateExplosions(dt); updateCoins(dt); updateGlobalAbilitiesCooldowns();
    
    if(selectedTower) { if (selectedTower.tiers.some(t => t >= 5) && !selectedTower.isParagon) document.getElementById('btn-paragon').disabled = GameState.money < 15000; }

    for (let i = enemies.length - 1; i >= 0; i--) {
        if (enemies[i].active) enemies[i].update(dt);
        else enemies.splice(i, 1);
    }
    
    towers.forEach(t => { if(t.radar) t.radar.rotation.y += dt*2; });
    renderer.render(scene, camera);
}
window.addEventListener('resize', () => { camera.aspect = window.innerWidth / window.innerHeight; camera.updateProjectionMatrix(); renderer.setSize(window.innerWidth, window.innerHeight); });
animate();
