        .map-icon { font-size: 40px; margin-bottom: 10px; }

        .panel { background: rgba(0,0,0,0.85); padding: 15px; border-radius: 8px; pointer-events: auto; border: 1px solid #444; box-shadow: 0 4px 15px rgba(0,0,0,0.5); backdrop-filter: blur(5px); }
        .top-bar { display: flex; justify-content: space-between; align-items: center; font-size: 24px; font-weight: bold; text-shadow: 2px 2px 0 #000; }
        .stats { display: flex; gap: 20px; }
        .currency { color: #ffd700; }
