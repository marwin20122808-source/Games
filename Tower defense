        .wave { color: #00ffcc; }
        
        .speed-controls { display: flex; gap: 5px; pointer-events: auto; }
        .spd-btn { background: #222; color: white; border: 2px solid #555; padding: 5px 15px; cursor: pointer; font-weight: bold; border-radius: 4px; }
        .spd-btn.active { background: #00ffcc; color: black; border-color: #00ffcc; }

        #build-panel { position: absolute; top: 80px; left: 20px; width: 440px; display: grid; grid-template-columns: 1fr 1fr; gap: 8px; padding-top: 40px; max-height: 80vh; overflow-y: auto; }
        #build-header { position: absolute; top: 15px; left: 15px; font-size: 16px; font-weight: bold; grid-column: span 2; }
        
        #upgrade-panel { position: absolute; bottom: 20px; left: 20px; width: 300px; display: none; }
        
        #ability-bar { position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); display: flex; gap: 10px; pointer-events: auto; }
        .ability-btn { position: relative; width: 60px; height: 60px; background: #331155; border: 2px solid #aa00ff; border-radius: 8px; cursor: pointer; display: flex; justify-content: center; align-items: center; font-size: 30px; overflow: hidden; box-shadow: 0 0 10px #aa00ff; transition: 0.2s; }
        .ability-btn:hover { background: #551188; transform: scale(1.1); }
        .cooldown-overlay { position: absolute; bottom: 0; left: 0; width: 100%; height: 0%; background: rgba(0,0,0,0.7); pointer-events: none; }

        .btn { display: block; width: 100%; padding: 10px; background: #222; color: white; border: 2px solid #555; cursor: pointer; font-weight: bold; transition: 0.2s; border-radius: 4px; text-align: left; }
        .btn:hover { background: #333; border-color: #888; }
        .btn:disabled { background: #111; color: #444; border-color: #222; cursor: not-allowed; }
        .btn.active { background: #00ffcc; color: black; border-color: #00ffcc; }
        .btn.remove-mode { background: #880000; border-color: #ff0000; color: white; }
        
        #btn-paragon { display: none; background: #ffffff; color: #000; border-color: #ffd700; text-align: center; font-size: 16px; margin-top: 10px; text-transform: uppercase; font-weight: 900; box-shadow: 0 0 15px #ffffff; }
        #btn-paragon:hover { background: #dddddd; }

        #btn-sell { background: #660000; border-color: #ff4444; text-align: center; margin-top: 10px; }
        #btn-sell:hover { background: #990000; }

        .tower-info { font-size: 10px; color: #aaa; margin-top: 4px; font-weight: normal; }
        .path-label { display: flex; justify-content: space-between; margin-bottom: 3px; }
        #tower-name { font-size: 20px; margin-bottom: 5px; color: #00ffcc; text-transform: uppercase; font-weight: 900;}
        
        .instruction { position: absolute; top: 80px; right: 20px; font-size: 13px; color: #ccc; text-align: right; background: rgba(0,0,0,0.7); padding: 15px; border-radius: 8px; border: 1px solid #333;}
        
        #wave-announcer { position: absolute; top: 30%; left: 50%; transform: translate(-50%, -50%); font-size: 80px; font-weight: 900; color: #fff; text-shadow: 0 0 20px #00ffcc, 0 0 40px #00ffcc; opacity: 0; pointer-events: none; transition: opacity 0.5s ease-in-out; z-index: 1000; }

        .floating-text { position: absolute; font-size: 22px; font-weight: 900; pointer-events: none; transform: translate(-50%, -50%); text-shadow: 2px 2px 0 #000, -2px -2px 0 #000, 2px -2px 0 #000, -2px 2px 0 #000; z-index: 1000; animation: floatUp 1.2s ease-out forwards; }
        @keyframes floatUp { 0% { transform: translate(-50%, -50%) scale(0.5); opacity: 0; } 15% { transform: translate(-50%, -80%) scale(1.2); opacity: 1; } 100% { transform: translate(-50%, -200%) scale(1); opacity: 0; } }
    </style>
