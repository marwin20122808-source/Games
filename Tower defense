        let forward = new THREE.Vector3(0,0,-1).applyQuaternion(camera.quaternion); forward.y = 0; forward.normalize();
        camTarget.addScaledVector(right, -dx * 0.05); camTarget.addScaledVector(forward, dy * 0.05);
        updateCamera();
    }
    if (isOrbiting) { camTheta -= dx * 0.01; camPhi -= dy * 0.01; updateCamera(); }
});
