<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Grand Virtual Casino</title>
    <style>
        /* --- GLOBAL & UI RESET --- */
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', sans-serif; user-select: none; }
        body { background-color: #111; color: #fff; overflow-x: hidden; }
        button { cursor: pointer; border: none; border-radius: 5px; font-weight: bold; transition: 0.2s; }
        button:hover:not(:disabled) { transform: scale(1.05); filter: brightness(1.2); }
        button:disabled { opacity: 0.5; cursor: not-allowed; }
        
        /* --- VIEWS --- */
        .view { display: none; min-height: 100vh; flex-direction: column; align-items: center; justify-content: center; overflow-y: auto; overflow-x: hidden; padding-bottom: 50px; }
        .view.active { display: flex; }

        /* --- MENUS --- */
        .container { background: #222; padding: 40px; border-radius: 10px; text-align: center; box-shadow: 0 0 20px rgba(255, 215, 0, 0.2); border: 2px solid #D4AF37; }
        h1 { color: #D4AF37; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 2px; }
        p { margin-bottom: 20px; font-size: 1.2rem; color: #ccc; }
        .input-group { margin-bottom: 20px; display: flex; justify-content: center; align-items: center; gap: 10px; }
        input[type="number"] { padding: 10px; font-size: 1.2rem; width: 150px; text-align: center; border-radius: 5px; border: 1px solid #D4AF37; background: #333; color: #fff; }
        .btn { padding: 12px 24px; font-size: 1.2rem; background: #D4AF37; color: #000; margin: 5px; }
        .player-inputs { display: flex; gap: 40px; justify-content: center; margin-bottom: 20px; }
        .player-buyin { display: flex; flex-direction: column; align-items: center; }
        
        .game-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 20px; width: 100%; max-width: 1000px; }
        .game-card { background: #333; padding: 30px; border-radius: 10px; border: 1px solid #555; text-align: center; cursor: pointer; transition: 0.3s; }
        .game-card:hover { border-color: #D4AF37; box-shadow: 0 0 15px rgba(212, 175, 55, 0.5); transform: translateY(-5px); }
        .game-card h2 { color: #D4AF37; }
        .game-card p { margin-top: 10px; font-size: 0.9rem; }
        .badge { background: #1976d2; color: #fff; padding: 2px 8px; border-radius: 5px; font-size: 0.8rem; font-weight: bold; margin-bottom: 10px; display: inline-block; }

        /* --- CASINO TABLES SHARED --- */
        .top-bar { width: 100%; display: flex; justify-content: space-between; padding: 15px 40px; background: #000; border-bottom: 2px solid #D4AF37; z-index: 10; position: sticky; top: 0; }
        .stats { font-size: 1.2rem; color: #D4AF37; font-family: monospace; font-weight: bold; }
        
        .table-felt {
            position: relative; width: 95%; max-width: 1300px; min-height: 65vh; margin-top: 20px;
            background: radial-gradient(circle at top, #0B6623, #043d12);
            border-bottom-left-radius: 50% 200px; border-bottom-right-radius: 50% 200px;
            border-top-left-radius: 200px 100px; border-top-right-radius: 200px 100px;
            border: 15px solid #4a2e15; border-top: 5px solid #2a1a0c;
            box-shadow: inset 0 -20px 50px rgba(0,0,0,0.8), 0 20px 30px rgba(0,0,0,0.5);
            display: flex; flex-direction: column; align-items: center; padding-bottom: 150px;
        }

        .history-board { position: absolute; top: 20px; left: 30px; display: flex; gap: 8px; flex-wrap: wrap; max-width: 250px; background: rgba(0,0,0,0.7); padding: 15px; border-radius: 10px; border: 2px solid #D4AF37; z-index: 5; box-shadow: 0 5px 15px rgba(0,0,0,0.8); }
        .hist-title { width: 100%; font-size: 0.9rem; color: #D4AF37; text-transform: uppercase; font-weight: bold; margin-bottom: 5px; text-align: center; border-bottom: 1px solid #555; padding-bottom: 5px; }
        .hist-circ { width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.1rem; color: #fff; border: 2px solid rgba(255,255,255,0.3); box-shadow: 2px 2px 5px rgba(0,0,0,0.8); }

        /* --- CHIPS & CONTROLS --- */
        .chip { width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1rem; border: 4px dashed #fff; cursor: pointer; box-shadow: 2px 4px 5px rgba(0,0,0,0.6); transition: 0.2s; z-index: 20; }
        .chip.c5 { background: #d32f2f; color: #fff; } .chip.c25 { background: #388e3c; color: #fff; } .chip.c100 { background: #111; color: #fff; border-color: #D4AF37; } .chip.c500 { background: #9c27b0; color: #fff; } .chip.c1000 { background: #ff9800; color: #000; }
        .ui-chip.selected { transform: scale(1.2) translateY(-5px); box-shadow: 0 0 15px #D4AF37; border-color: #D4AF37; }
        .stacked-chip { position: absolute; pointer-events: none; width: 40px; height: 40px; font-size: 0.8rem; border-width: 2px; }

        .shared-ui-panel { background: #111; width: 100%; padding: 20px; z-index: 10; text-align: center; flex-grow: 1; border-top: 2px solid #333; }
        .message-board { font-size: 1.5rem; color: #fff; margin-bottom: 15px; height: 30px; font-weight: bold; text-shadow: 1px 1px 5px #000; }
        .controls-row { display: flex; justify-content: center; gap: 15px; margin-bottom: 10px; align-items: center; flex-wrap: wrap; }
        .action-btn { padding: 12px 20px; font-size: 1.1rem; background: #fff; color: #000; border: 2px solid #000; min-width: 110px; text-transform: uppercase; letter-spacing: 1px; }
        .action-btn:hover:not(:disabled) { background: #D4AF37; color: #000; border-color: #D4AF37; }
        .setting-select { padding: 8px 15px; background: #222; color: #D4AF37; border: 2px solid #D4AF37; border-radius: 5px; font-size: 1.1rem; font-weight: bold; outline: none; cursor: pointer; }

        /* --- CARDS GLOBAL --- */
        .card { width: 90px; height: 130px; background: #fff; border-radius: 8px; border: 1px solid #ccc; display: flex; flex-direction: column; justify-content: space-between; padding: 5px; font-size: 1.5rem; font-weight: bold; position: absolute; box-shadow: 2px 2px 10px rgba(0,0,0,0.5); }
        .card.red { color: #d32f2f; } .card.black { color: #000; }
        .card .top-left { text-align: left; line-height: 1; font-size: 1.2rem; } .card .center-suit { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 2.5rem; }
        .card.hidden { background: #b71c1c; background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(255,255,255,0.1) 10px, rgba(255,255,255,0.1) 20px); border: 2px solid #fff; color: transparent; } .card.hidden * { display: none; }
        .anim-deal { animation: dealCard 0.4s ease-out forwards; } @keyframes dealCard { from { transform: translate(300px, -300px) scale(0.5); opacity: 0; } to { transform: translate(0, 0) scale(1); opacity: 1; } }
        #shoe-box { position: absolute; top: 20px; right: 40px; width: 60px; height: 90px; background: #111; border: 3px solid #555; border-radius: 5px; box-shadow: 5px 5px 15px rgba(0,0,0,0.8); display: flex; flex-direction: column; justify-content: flex-end; padding: 5px; }
        .shoe-cards { width: 100%; height: 60px; background: #fff; border-top: 4px solid #b71c1c; border-left: 1px solid #ccc; border-radius: 2px; }

        /* */
        /* ================= BLACKJACK SPECIFIC ================= */
        .dealer-area { min-height: 160px; margin-top: 20px; display: flex; flex-direction: column; align-items: center; }
        .dealer-cards-container { position: relative; height: 140px; width: 220px; display: flex; justify-content: center; }
        .betting-area { display: flex; justify-content: center; gap: 80px; position: absolute; bottom: 80px; width: 100%; }
        .spot-container { display: flex; flex-direction: column; align-items: center; position: relative; }
        .betting-circle { width: 90px; height: 90px; border: 3px solid rgba(255,255,255,0.4); border-radius: 50%; display: flex; justify-content: center; align-items: center; position: relative; cursor: pointer; transition: 0.2s; background: rgba(0,0,0,0.1); }
        .betting-circle:hover { border-color: #D4AF37; background: rgba(212, 175, 55, 0.2); } .betting-circle.active-turn { border-color: #D4AF37; box-shadow: 0 0 20px #D4AF37; }
        .spot-text { position: absolute; color: rgba(255,255,255,0.4); font-weight: bold; pointer-events: none; text-align: center; font-size: 0.8rem; }
        .cards { display: flex; justify-content: center; position: absolute; bottom: 100px; height: 140px; pointer-events: none; }
        .anim-deal-double { animation: dealDouble 0.4s ease-out forwards; } .is-double { transform: rotate(90deg) translate(20px, 30px); } @keyframes dealDouble { from { transform: translate(300px, -300px) scale(0.5) rotate(0deg); opacity: 0; } to { transform: rotate(90deg) translate(20px, 30px); opacity: 1; } }
        .status-badge { position: absolute; top: -30px; background: rgba(0,0,0,0.8); color: #fff; padding: 2px 10px; border-radius: 5px; font-size: 0.9rem; font-weight: bold; border: 1px solid #D4AF37; white-space: nowrap; z-index: 50; }

        /* ================= ROULETTE SPECIFIC ================= */
        .r-layout { display: flex; flex-direction: column; align-items: center; width: 100%; height: 100%; padding: 20px; }
        .r-wheel-container { position: relative; width: 360px; height: 360px; border-radius: 50%; border: 15px solid #3e2723; background: #111; box-shadow: 0 20px 40px rgba(0,0,0,0.9), inset 0 0 15px #000; margin-bottom: 40px; overflow: hidden; }
        .r-wheel-slices { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 50%; transition: transform 5s cubic-bezier(0.1, 0.7, 0.1, 1); }
        .r-conic-bg { position: absolute; width: 100%; height: 100%; border-radius: 50%; }
        .wheel-num { position: absolute; top: 50%; left: 50%; width: 20px; height: 20px; margin-left: -10px; margin-top: -10px; color: #fff; font-size: 0.95rem; font-weight: bold; text-align: center; line-height: 20px; text-shadow: 1px 1px 2px #000; z-index: 2; }
        .r-ball-track { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 50%; z-index: 10; transition: transform 5s cubic-bezier(0.1, 0.7, 0.1, 1); }
        .r-ball { position: absolute; left: calc(50% - 7px); top: 5px; width: 14px; height: 14px; background: radial-gradient(circle at 30% 30%, #fff, #bbb); border-radius: 50%; display: none; box-shadow: 2px 2px 5px rgba(0,0,0,0.8); transition: top 1.5s cubic-bezier(0.1, 0.7, 0.1, 1); }
        .r-wheel-hub { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 150px; height: 150px; background: radial-gradient(circle, #6d4c41, #3e2723); border-radius: 50%; border: 4px solid #D4AF37; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 20px rgba(0,0,0,0.9); z-index: 15; }
        .r-wheel-center-display { width: 90px; height: 90px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; font-weight: bold; color: #fff; text-shadow: 2px 2px 5px #000; transition: background-color 0.4s ease; }
        .r-board { display: grid; grid-template-columns: 70px repeat(12, 70px); grid-template-rows: repeat(3, 70px) 50px 50px 50px; gap: 4px; background: rgba(0,0,0,0.6); padding: 10px; border: 3px solid #D4AF37; border-radius: 10px; box-shadow: 0 15px 30px rgba(0,0,0,0.8); }
        .r-cell { display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.5rem; cursor: pointer; position: relative; color: #fff; border: 1px solid rgba(255,255,255,0.3); transition: 0.2s; }
        .r-cell:hover { border-color: #D4AF37; z-index: 5; box-shadow: 0 0 15px rgba(212,175,55,1); transform: scale(1.05); }
        .r-zero { grid-row: 1 / 4; grid-column: 1; background: #388e3c; border-radius: 5px 0 0 5px; }  .r-red { background: #d32f2f; } .r-black { background: #111; }
        .r-outside { grid-row: 4; background: #222; font-size: 1.2rem; } .r-out-red { grid-column: 2 / 8; background: #d32f2f; } .r-out-black { grid-column: 8 / 14; background: #111; }
        .r-out-even { grid-column: 2 / 8; grid-row: 5; background: #222;} .r-out-odd { grid-column: 8 / 14; grid-row: 5; background: #222;}
        .r-out-low { grid-column: 2 / 8; grid-row: 6; background: #222; border-radius: 0 0 0 5px;} .r-out-high { grid-column: 8 / 14; grid-row: 6; background: #222; border-radius: 0 0 5px 0;}

        /* ================= BACCARAT SPECIFIC ================= */
        .bac-layout { width: 100%; display: flex; flex-direction: column; align-items: center; height: 100%; justify-content: space-between; padding-top: 40px; }
        .bac-cards-area { display: flex; width: 100%; max-width: 800px; justify-content: space-between; padding: 0 50px; margin-bottom: 20px; }
        .bac-hand { flex: 1; display: flex; flex-direction: column; align-items: center; }
        .bac-title { font-size: 1.8rem; font-weight: bold; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 5px; text-shadow: 2px 2px 5px #000; }
        .bac-title.player { color: #2196F3; } .bac-title.banker { color: #f44336; }
        .bac-score { font-size: 1.5rem; color: #fff; background: rgba(0,0,0,0.6); padding: 5px 15px; border-radius: 20px; border: 1px solid #D4AF37; margin-bottom: 15px; min-width: 50px; text-align: center; }
        .bac-cards-container { position: relative; height: 140px; width: 220px; display: flex; justify-content: center; }
        .bac-board { display: flex; flex-direction: column; width: 90%; max-width: 800px; gap: 5px; border: 4px solid #D4AF37; border-radius: 10px; background: rgba(0,0,0,0.6); overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.8); }
        .bac-row { display: flex; width: 100%; }
        .bac-zone { flex: 1; padding: 20px 10px; text-align: center; cursor: pointer; position: relative; display: flex; flex-direction: column; justify-content: center; align-items: center; transition: 0.2s; border: 1px solid rgba(255,215,0,0.3); }
        .bac-zone:hover { background: rgba(212, 175, 55, 0.2); }
        .bac-z-title { font-size: 1.8rem; font-weight: bold; text-transform: uppercase; text-shadow: 1px 1px 3px #000; }
        .bac-z-sub { font-size: 0.9rem; color: #D4AF37; font-weight: bold; margin-top: 5px; }
        .bz-tie { color: #4CAF50; } .bz-banker { color: #f44336; } .bz-player { color: #2196F3; } .bz-pair { color: #D4AF37; font-size: 1.2rem; }
        .bac-results-overlay { position: absolute; top: 45%; left: 50%; transform: translate(-50%, -50%); font-size: 4rem; font-weight: bold; color: #D4AF37; text-transform: uppercase; text-shadow: 0 0 20px #000, 0 0 40px #D4AF37; z-index: 100; opacity: 0; transition: opacity 0.5s; pointer-events: none; white-space: nowrap; }

        /* ================= SLOTS SPECIFIC ================= */
        .slot-machine { background: linear-gradient(to bottom, #d32f2f, #b71c1c); border: 8px solid #D4AF37; border-radius: 20px; padding: 30px; box-shadow: 0 15px 30px rgba(0,0,0,0.8), inset 0 0 20px #000; width: 100%; max-width: 600px; display: flex; flex-direction: column; align-items: center; margin-top: 40px; }
        .slot-title { font-size: 2.5rem; color: #D4AF37; text-transform: uppercase; font-weight: bold; text-shadow: 2px 2px 5px #000; margin-bottom: 20px; letter-spacing: 3px; }
        .slot-paytable { background: rgba(0,0,0,0.5); padding: 15px; border-radius: 5px; font-size: 0.9rem; color: #D4AF37; width: 100%; display: flex; flex-wrap: wrap; justify-content: center; gap: 15px; margin-bottom: 20px; border: 1px solid #D4AF37; font-weight: bold; }
        .slot-reels { display: flex; gap: 15px; background: #222; padding: 20px; border-radius: 10px; border: 4px solid #555; box-shadow: inset 0 10px 20px rgba(0,0,0,0.9); margin-bottom: 20px; }
        .reel { width: 90px; height: 120px; background: #fff; border-radius: 5px; display: flex; align-items: center; justify-content: center; font-size: 4.5rem; box-shadow: inset 0 5px 10px rgba(0,0,0,0.3); border: 2px solid #ccc; text-shadow: 2px 2px 5px rgba(0,0,0,0.2); }
        .slot-win-display { font-size: 1.5rem; font-weight: bold; background: #000; color: #D4AF37; width: 100%; text-align: center; padding: 10px; border-radius: 5px; border: 2px solid #D4AF37; text-shadow: 0 0 5px #D4AF37; transition: 0.3s; height: 50px; display: flex; align-items: center; justify-content: center; text-transform: uppercase; }

        /* ================= PLINKO SPECIFIC ================= */
        .plinko-container { width: 100%; max-width: 800px; margin-top: 30px; position: relative; }
        #plinko-canvas { width: 100%; height: auto; background: #0c0c0c; border: 5px solid #D4AF37; border-radius: 15px; box-shadow: 0 20px 50px rgba(0,0,0,0.9), inset 0 0 30px rgba(0,0,0,1); display: block; }
        .plinko-controls-header { display: flex; justify-content: center; gap: 20px; margin-bottom: 20px; align-items: center; flex-wrap: wrap; background: rgba(0,0,0,0.5); padding: 15px; border-radius: 10px; border: 1px solid #555; }
    </style>
</head>
<body>
    <!-- ================= LOBBY ================= -->
    <div id="lobby-view" class="view active">
        <div class="container">
            <h1 style="font-size: 2.5rem;">Grand Virtual Casino</h1>
            <p>Select Game Mode to begin.</p>
            <div class="controls-row">
                <button class="btn" onclick="selectPlayers(1)">1 Player</button>
                <button class="btn" onclick="selectPlayers(2)">2 Players</button>
            </div>
        </div>
    </div>

    <!-- ================= CASHIER ================= -->
    <div id="cashier-view" class="view">
        <div class="container">
            <h1>Cashier</h1>
            <div class="player-inputs" id="cashier-inputs"></div>
            <button class="btn" onclick="cashIn()">Get Chips</button>
        </div>
    </div>

    <!-- ================= FLOOR ================= -->
    <div id="floor-view" class="view">
        <div class="container" style="max-width: 1000px; width: 95%;">
            <h1>Casino Floor</h1>
            <div id="floor-stats" style="margin-bottom: 20px;"></div>
            <div class="game-grid">
                <div class="game-card" onclick="openGame('blackjack')">
                    <h2>♠♥ Blackjack</h2><p>Pays 3:2 • Soft 17 • Surrender</p>
                </div>
                <div class="game-card" onclick="openGame('roulette')">
                    <h2>🎡 Roulette</h2><p>Vegas Standard • History Board</p>
                </div>
                <div class="game-card" onclick="openGame('baccarat')">
                    <h2>🎴 Baccarat</h2><p>Standard Payouts • Bead Road</p>
                </div>
                <div class="game-card" onclick="openGame('slots')">
                    <div class="badge">CUSTOM RULES</div>
                    <h2>🎰 Lucky 7s</h2><p>500x Jackpots • 1x Match-2 Push</p>
                </div>
                <div class="game-card" onclick="openGame('plinko')">
                    <div class="badge">STAKE.COM RULES</div>
                    <h2>🎯 Plinko Drop</h2><p>Authentic 99% RTP Paytables</p>
                </div>
            </div>
            <br><button class="btn" style="background: #d32f2f; color:#fff; margin-top: 20px;" onclick="cashOut()">Cash Out & Leave</button>
        </div>
    </div>

    <!-- ================= BLACKJACK VIEW ================= -->
    <div id="blackjack-view" class="view">
        <div class="top-bar">
            <div id="bj-bankrolls" style="display: flex; gap: 30px;"></div>
            <button class="btn" style="padding: 5px 15px; margin:0;" onclick="leaveTable('blackjack')">Leave Table</button>
        </div>
        <div class="table-felt">
            <div style="position: absolute; top: 10px; left: 0; width: 100%; text-align: center; color: rgba(255,255,255,0.4); font-size: 1.2rem; font-weight: bold; pointer-events:none;">DEALER MUST HIT SOFT 17<br>BLACKJACK PAYS 3 TO 2<br>INSURANCE PAYS 2 TO 1</div>
            <div id="bj-shoe-box" id="shoe-box"><div class="shoe-cards" id="bj-shoe-visual"></div><div style="color:#ccc; font-size:0.7rem; text-align:center;">8 DECKS</div></div>
            <div class="dealer-area">
                <div style="font-size: 1.2rem; color: rgba(255,255,255,0.7); font-weight: bold; margin-bottom: 5px;">Dealer <span id="dealer-score-display"></span></div>
                <div id="dealer-cards" class="dealer-cards-container"></div>
            </div>
            <div class="betting-area">
                <div class="spot-container" id="container-0"><div class="cards" id="cards-0"></div><div class="betting-circle" id="spot-0" onclick="bjPlaceBet(0)"><span class="spot-text">P1<br>BET</span></div></div>
                <div class="spot-container" id="container-1"><div class="cards" id="cards-1"></div><div class="betting-circle" id="spot-1" onclick="bjPlaceBet(1)"><span class="spot-text">P1<br>BET</span></div></div>
                <div class="spot-container" id="container-2"><div class="cards" id="cards-2"></div><div class="betting-circle" id="spot-2" onclick="bjPlaceBet(2)"><span class="spot-text">P2<br>BET</span></div></div>
            </div>
        </div>
        <div class="shared-ui-panel">
            <div class="message-board" id="bj-msg">Place your bets.</div>
            <div id="bj-betting-controls" class="controls-row">
                <div class="chip ui-chip c5" onclick="selectChip(5, this)">$5</div><div class="chip ui-chip c25" onclick="selectChip(25, this)">$25</div><div class="chip ui-chip c100" onclick="selectChip(100, this)">$100</div><div class="chip ui-chip c500" onclick="selectChip(500, this)">$500</div><div class="chip ui-chip c1000" onclick="selectChip(1000, this)">$1k</div>
                <div style="margin-left: 20px; border-left: 1px solid #333; padding-left: 20px;">
                    <button class="action-btn" onclick="bjClearBets()">Clear</button>
                    <button class="action-btn" id="btn-deal" style="background: #D4AF37;" onclick="bjDeal()" disabled>Deal</button>
                </div>
            </div>
            <!-- Insurance Controls -->
            <div id="bj-insurance-controls" class="controls-row" style="display: none;">
                <button class="action-btn" style="background: #4CAF50; color: #fff;" onclick="bjTakeInsurance(true)">Yes, Insure</button>
                <button class="action-btn" style="background: #f44336; color: #fff;" onclick="bjTakeInsurance(false)">No, Pass</button>
            </div>
            <!-- Action Controls -->
            <div id="bj-action-controls" class="controls-row" style="display: none;">
                <button class="action-btn" id="btn-hit" onclick="bjHit()">Hit</button>
                <button class="action-btn" id="btn-stand" onclick="bjStand()">Stand</button>
